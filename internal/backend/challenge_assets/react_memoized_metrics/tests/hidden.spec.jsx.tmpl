import React from "react";
import { render } from "@testing-library/react";
import { describe, expect, it, vi } from "vitest";
import {{component_name}} from "../src/App.jsx";

const items = [
  { id: "1", passed: true, label: "Ada" },
  { id: "2", passed: false, label: "Grace" }
];

describe("{{component_name}} hidden checks", () => {
  it("does not recompute when unrelated props change [quality:memoized-summary]", () => {
    const computeSummary = vi.fn((records) => ({
      total: records.length,
      passing: records.filter((record) => record.passed).length,
      latestLabel: records[records.length - 1].label
    }));

    const { rerender } = render(
      <{{component_name}}
        items={items}
        heading="Before"
        computeSummary={computeSummary}
      />
    );

    rerender(
      <{{component_name}}
        items={items}
        heading="After"
        computeSummary={computeSummary}
      />
    );

    expect(computeSummary).toHaveBeenCalledTimes(1);
  });
});
