import React, { useEffect, useState } from "react";

export function {{component_name}}({
  teamId = "frontend",
  loadMembers,
  emptyMessage = "{{empty_state}}"
}) {
  const [status, setStatus] = useState("idle");
  const [members, setMembers] = useState([]);
  const [error, setError] = useState("");

  useEffect(() => {
    let active = true;
    setStatus("loading");
    setError("");
    // TODO request members for the current teamId, ignore stale responses, and surface errors.
    return () => {
      active = false;
    };
  }, [teamId, loadMembers]);

  return (
    <section>
      <p aria-label="status">{status}</p>
      {status === "error" ? <p role="alert">{error}</p> : null}
      {status === "success" && members.length === 0 ? <p>{emptyMessage}</p> : null}
      <ul aria-label="team members">
        {members.map((member) => (
          <li key={member.id}>{member.name}</li>
        ))}
      </ul>
    </section>
  );
}

export default {{component_name}};
